# Create a local .env file and replace the value below with your RAWG API key.
# Never commit the real key. Obtain one at https://rawg.io/apidocs
RAWG_API_KEY=replace_with_your_rawg_api_key
TWITCH_CLIENT_ID=replace_with_your_twitch_client_id
TWITCH_CLIENT_SECRET=replace_with_your_twitch_client_secret
